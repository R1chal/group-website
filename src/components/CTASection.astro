---

<section id="join" class="py-20 sm:py-28 bg-gradient-to-b from-spotify-black to-spotify-mid/20">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- Heading -->
    <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-spotify-white mb-6 delay-100" data-animate="fade-in-up">
      准备好加入了吗？
    </h2>

    <p class="text-lg text-spotify-silver max-w-xl mx-auto mb-10 delay-200" data-animate="fade-in-up">
      立即注册，成为社区的一员。与数千名成员一起，开启你的探索之旅。
    </p>

    <!-- CTA Button -->
    <a
      href="#"
      class="inline-flex items-center px-10 py-4 bg-spotify-green text-spotify-black text-sm font-bold uppercase tracking-widest rounded-full hover:scale-105 hover:bg-spotify-green-hover transition-all duration-200 delay-300"
      data-animate="fade-in-up"
    >
      免费加入社区
    </a>

    <!-- Trust indicators -->
    <div class="mt-10 flex flex-wrap items-center justify-center gap-6 text-sm text-spotify-silver delay-400" data-animate="fade-in-up">
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-spotify-green" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
        </svg>
        永久免费
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-spotify-green" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
        </svg>
        无需信用卡
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-spotify-green" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
        </svg>
        随时退出
      </span>
    </div>
  </div>
</section>
