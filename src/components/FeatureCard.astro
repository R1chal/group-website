---
export interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<div class="group bg-spotify-dark rounded-lg p-6 hover:bg-spotify-card transition-all duration-300 hover:shadow-[rgba(0,0,0,0.3)_0px_8px_8px]">
  <div class="w-12 h-12 bg-spotify-mid rounded-full flex items-center justify-center mb-4 group-hover:bg-spotify-green/20 transition-colors">
    <Fragment set:html={icon} />
  </div>
  <h3 class="text-base font-bold text-spotify-white mb-2">{title}</h3>
  <p class="text-sm text-spotify-silver leading-relaxed">{description}</p>
</div>
