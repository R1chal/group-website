---
import FeatureCard from './FeatureCard.astro';

const features = [
  {
    title: "实时交流",
    description: "与群组成员进行即时文字和语音交流，随时随地分享想法和见解。",
    icon: `<svg class="w-6 h-6 text-spotify-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>`
  },
  {
    title: "主题频道",
    description: "按兴趣划分多个频道，从音乐到社会热点，从科技到生活，找到属于你的话题。",
    icon: `<svg class="w-6 h-6 text-spotify-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>`
  },
  {
    title: "活动日历",
    description: "不错过任何精彩活动。线上分享会、AMA 问答、协作项目，应有尽有。",
    icon: `<svg class="w-6 h-6 text-spotify-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`
  },
  {
    title: "资源共享",
    description: "成员共享优质资源、教程和工具。知识在这里流动，每个人都在成长。",
    icon: `<svg class="w-6 h-6 text-spotify-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>`
  },
  {
    title: "隐私安全",
    description: "端到端加密通讯，严格的社区准则，确保每位成员的安全和舒适体验。",
    icon: `<svg class="w-6 h-6 text-spotify-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>`
  },
  {
    title: "跨平台同步",
    description: "Web、iOS、Android 全平台覆盖，无论身在何处，社区始终与你同行。",
    icon: `<svg class="w-6 h-6 text-spotify-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>`
  }
];
---

<section id="features" class="py-20 sm:py-28 bg-spotify-black">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16" data-animate="fade-in-up">
      <h2 class="text-3xl sm:text-4xl font-bold text-spotify-white mb-4">为什么选择我们</h2>
      <p class="text-lg text-spotify-silver max-w-2xl mx-auto">
        一个为创作者和探索者打造的社区，在这里连接、分享、共同成长。
      </p>
    </div>

    <!-- Features grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((feature, i) => (
        <FeatureCard {...feature} index={i} />
      ))}
    </div>
  </div>
</section>
