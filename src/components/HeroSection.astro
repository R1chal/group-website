---
---

<section class="relative min-h-screen flex items-center justify-center bg-spotify-black pt-16">
  <!-- Background gradient effect -->
  <div class="absolute inset-0 bg-gradient-to-b from-spotify-mid/30 via-spotify-black to-spotify-black"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-spotify-mid rounded-full mb-8 delay-100" data-animate="fade-in-up">
      <span class="w-2 h-2 bg-spotify-green rounded-full animate-pulse"></span>
      <span class="text-xs font-semibold text-spotify-white uppercase tracking-wide">开放加入中</span>
    </div>

    <!-- Main heading -->
    <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-spotify-white leading-tight mb-6 delay-200" data-animate="fade-in-up">
      连接<br class="sm:hidden" />
      <span class="text-spotify-green">志同道合</span>的伙伴
    </h1>

    <!-- Subtitle -->
    <p class="text-lg sm:text-xl text-spotify-silver max-w-2xl mx-auto mb-10 leading-relaxed delay-300" data-animate="fade-in-up">
      在这里，每个声音都被听见。加入我们的群组，与来自世界各地的创作者、思考者和行动者一起，构建属于你的社区。
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 delay-400" data-animate="fade-in-up">
      <a
        href="#join"
        class="w-full sm:w-auto px-8 py-4 bg-spotify-green text-spotify-black text-sm font-bold uppercase tracking-widest rounded-full hover:scale-105 hover:bg-spotify-green-hover transition-all duration-200"
      >
        免费加入
      </a>
      <a
        href="#features"
        class="w-full sm:w-auto px-8 py-4 bg-transparent text-spotify-white text-sm font-bold uppercase tracking-widest rounded-full border border-spotify-border-light hover:border-spotify-white transition-all duration-200"
      >
        了解更多
      </a>
    </div>

    <!-- Stats -->
    <div class="mt-16 grid grid-cols-3 gap-8 max-w-lg mx-auto delay-500" data-animate="fade-in-up">
      <div class="text-center">
        <div class="text-2xl sm:text-3xl font-bold text-spotify-white">50+</div>
        <div class="text-sm text-spotify-silver mt-1">活跃成员</div>
      </div>
      <div class="text-center">
        <div class="text-2xl sm:text-3xl font-bold text-spotify-white">♾️</div>
        <div class="text-sm text-spotify-silver mt-1">每日话题</div>
      </div>
      <div class="text-center">
        <div class="text-2xl sm:text-3xl font-bold text-spotify-white">100%</div>
        <div class="text-sm text-spotify-silver mt-1">免费开放</div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-spotify-silver" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
    </svg>
  </div>
</section>
